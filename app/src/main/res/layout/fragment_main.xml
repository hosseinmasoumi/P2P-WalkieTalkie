<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent"
        app:navigationIcon="@drawable/ic_menu"
        app:title="@string/main_title"
        app:titleTextColor="@color/textPrimary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:scrollbars="none"
        app:layout_constraintBottom_toTopOf="@+id/snackbar_container"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Header Connection Status Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/cardBackground"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                app:strokeColor="#1AFFFFFF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">

                        <ImageView
                            android:id="@+id/iv_wifi_status"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_wifi"
                            app:tint="@color/greenAccent"
                            android:contentDescription="@null" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="16dp"
                            android:layout_toEndOf="@id/iv_wifi_status"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tv_connection_status_title"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/connected"
                                android:textColor="@color/greenAccent"
                                android:textSize="16sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tv_connection_status_desc"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/connected_to_group"
                                android:textColor="@color/textSecondary"
                                android:textSize="13sp" />
                        </LinearLayout>

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_check_circle"
                            app:tint="@color/greenAccent"
                            android:contentDescription="@null" />
                    </RelativeLayout>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:background="#1AFFFFFF" />

                    <RelativeLayout
                        android:id="@+id/rl_devices_info"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:background="?attr/selectableItemBackground">

                        <ImageView
                            android:id="@+id/iv_devices_mini"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_alignParentStart="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_group"
                            app:tint="@color/textSecondary"
                            android:contentDescription="@null" />

                        <TextView
                            android:id="@+id/tv_devices_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="12dp"
                            android:layout_toEndOf="@id/iv_devices_mini"
                            android:text="@string/sample_devices_count"
                            android:textColor="@color/textPrimary"
                            android:textSize="14sp" />

                        <ImageView
                            android:id="@+id/iv_chevron_right_main"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:src="@drawable/ic_chevron_right"
                            app:tint="@color/textSecondary"
                            android:contentDescription="@null" />
                    </RelativeLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Control Area -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:minHeight="360dp">

                <!-- Volume Meter -->
                <LinearLayout
                    android:id="@+id/volume_meter_container"
                    android:layout_width="16dp"
                    android:layout_height="220dp"
                    android:background="@drawable/search_card_background"
                    android:gravity="bottom"
                    android:orientation="vertical"
                    android:padding="2dp"
                    app:layout_constraintBottom_toBottomOf="@id/ptt_container"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ptt_container"
                    tools:ignore="RtlSymmetry">

                    <View
                        android:id="@+id/volume_meter_bar"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:background="@drawable/status_dot"
                        android:backgroundTint="@color/greenAccent" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/volume_level"
                    android:textColor="@color/textSecondary"
                    android:textSize="11sp"
                    app:layout_constraintEnd_toEndOf="@id/volume_meter_container"
                    app:layout_constraintStart_toStartOf="@id/volume_meter_container"
                    app:layout_constraintTop_toBottomOf="@id/volume_meter_container" />

                <!-- PTT Button -->
                <FrameLayout
                    android:id="@+id/ptt_container"
                    android:layout_width="240dp"
                    android:layout_height="240dp"
                    android:background="@drawable/ptt_button_outer"
                    android:padding="24dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_ptt"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/ptt_button_background"
                        android:contentDescription="@string/hold_to_talk"
                        app:backgroundTint="@null"
                        app:icon="@drawable/ic_mic"
                        app:iconGravity="top"
                        app:iconPadding="0dp"
                        app:iconSize="56dp"
                        app:iconTint="@android:color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="44dp"
                        android:text="@string/hold_to_talk"
                        android:textColor="@android:color/white"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <!-- Record Toggle -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/cardBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:layout_constraintBottom_toBottomOf="@id/ptt_container"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/ptt_container">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_mic"
                            app:tint="@color/textSecondary"
                            android:contentDescription="@null" />

                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:id="@+id/recordTransmissionsSwitch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:checked="false"
                            app:thumbTint="@android:color/white"
                            app:trackTint="@color/greenAccent" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="80dp"
                            android:gravity="center"
                            android:text="@string/record_transmissions"
                            android:textColor="@color/textSecondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bottom Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="100dp" />

        </LinearLayout>
    </ScrollView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/snackbar_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="16dp"
                        android:visibility="visible"
                        app:cardBackgroundColor="#E61E1E1E"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="8dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:strokeColor="#33FFFFFF"
                        app:strokeWidth="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:padding="16dp">

                            <ImageView
                                android:id="@+id/iv_snack_icon"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_info"
                                app:tint="@color/greenAccent"
                                android:contentDescription="@null" />

                            <TextView
                                android:id="@+id/tv_snack_text"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="12dp"
                                android:layout_toEndOf="@id/iv_snack_icon"
                                android:layout_toStartOf="@+id/btn_close_snack"
                                android:text="@string/not_connected"
                                android:textColor="@color/textPrimary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/btn_close_snack"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:padding="4dp"
                                android:text="@string/btn_close"
                                android:textColor="@color/greenAccent"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </RelativeLayout>
                    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
