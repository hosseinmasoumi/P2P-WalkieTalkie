<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <fragment
        android:id="@+id/splashFragment"
        android:name="com.tfajfar.walkietalkie.ui.connection.SplashFragment"
        android:label="SplashFragment"
        tools:layout="@layout/fragment_splash">
        <action
            android:id="@+id/action_splash_to_permissions"
            app:destination="@id/permissionsFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_splash_to_main"
            app:destination="@id/nav_talk"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/permissionsFragment"
        android:name="com.tfajfar.walkietalkie.ui.permissions.PermissionsFragment"
        android:label="PermissionsFragment"
        tools:layout="@layout/fragment_permissions">
        <action
            android:id="@+id/action_permissions_to_main"
            app:destination="@id/nav_talk"
            app:popUpTo="@id/permissionsFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/nav_talk"
        android:name="com.tfajfar.walkietalkie.ui.main.MainFragment"
        android:label="Talk"
        tools:layout="@layout/fragment_main" />

    <fragment
        android:id="@+id/nav_devices"
        android:name="com.tfajfar.walkietalkie.ui.discovery.DiscoveryFragment"
        android:label="Devices"
        tools:layout="@layout/fragment_discovery" />

    <fragment
        android:id="@+id/nav_recordings"
        android:name="com.tfajfar.walkietalkie.ui.recording.RecordingsFragment"
        android:label="Recordings"
        tools:layout="@layout/fragment_recordings" />

    <fragment
        android:id="@+id/nav_settings"
        android:name="com.tfajfar.walkietalkie.ui.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
