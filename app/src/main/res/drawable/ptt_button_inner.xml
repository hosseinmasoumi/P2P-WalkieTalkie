<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#FF6B6B"
                android:endColor="#C62828"/>
            <stroke android:width="3dp" android:color="#FFCDD2"/>
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#424242"
                android:endColor="#212121"/>
            <stroke android:width="1dp" android:color="#1AFFFFFF"/>
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="80dp"
                android:centerX="0.5"
                android:centerY="0.5"
                android:startColor="#E53935"
                android:endColor="#B71C1C"/>
            <stroke android:width="2dp" android:color="#4DFFFFFF"/>
        </shape>
    </item>
</selector>
