<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#FF5252"
                android:endColor="#D32F2F" />
            <stroke android:width="2dp" android:color="#FFCDD2" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="radial"
                android:gradientRadius="120dp"
                android:startColor="#F44336"
                android:endColor="#B71C1C" />
            <stroke android:width="1dp" android:color="#4DFFFFFF" />
            <size android:width="120dp" android:height="120dp" />
        </shape>
    </item>
</selector>
