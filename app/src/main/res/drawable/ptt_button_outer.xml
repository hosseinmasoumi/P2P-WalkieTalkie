<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer metallic ring -->
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="270"
                android:startColor="#444444"
                android:endColor="#222222" />
            <stroke android:width="2dp" android:color="#555555" />
        </shape>
    </item>

    <!-- Shadow/Depth ring -->
    <item android:top="8dp" android:bottom="8dp" android:left="8dp" android:right="8dp">
        <shape android:shape="oval">
            <solid android:color="#121212" />
            <stroke android:width="1dp" android:color="#000000" />
        </shape>
    </item>

    <!-- Inner subtle glow ring -->
    <item android:top="12dp" android:bottom="12dp" android:left="12dp" android:right="12dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#33FFFFFF" />
        </shape>
    </item>
</layer-list>
