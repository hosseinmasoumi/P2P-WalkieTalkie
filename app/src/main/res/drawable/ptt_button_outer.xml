<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <gradient
                android:type="linear"
                android:angle="135"
                android:startColor="#4A4A4A"
                android:centerColor="#2A2A2A"
                android:endColor="#1A1A1A"/>
            <stroke android:width="2dp" android:color="#666666"/>
        </shape>
    </item>
    <item android:top="6dp" android:bottom="6dp" android:left="6dp" android:right="6dp">
        <shape android:shape="oval">
            <solid android:color="#0D0D0D"/>
            <stroke android:width="1dp" android:color="#000000"/>
        </shape>
    </item>
    <item android:top="10dp" android:bottom="10dp" android:left="10dp" android:right="10dp">
        <shape android:shape="oval">
            <stroke android:width="1.5dp" android:color="#26FFFFFF"/>
        </shape>
    </item>
</layer-list>
