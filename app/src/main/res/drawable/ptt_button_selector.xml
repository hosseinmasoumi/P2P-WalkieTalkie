<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="oval">
            <solid android:color="@color/statusRed" />
            <stroke android:width="4dp" android:color="#4DFFFFFF" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/dotGrey" />
            <stroke android:width="4dp" android:color="#1AFFFFFF" />
        </shape>
    </item>
</selector>
